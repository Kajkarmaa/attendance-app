{
    "expo": {
        "name": "attendance",
        "slug": "attendance",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/logo.jpg",
        "scheme": "attendance",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": true
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#FFFFFF",
                "foregroundImage": "./assets/logo.jpg"
            },
            "edgeToEdgeEnabled": true,
            "predictiveBackGestureEnabled": false,
            "package": "com.attendanceapp.main"
        },
        "web": {
            "output": "static",
            "favicon": "./assets/logo.jpg"
        },
        "plugins": [
            "expo-router",
            [
                "expo-splash-screen",
                {
                    "image": "./assets/logo.jpg",
                    "imageWidth": 200,
                    "resizeMode": "contain",
                    "backgroundColor": "#ffffff",
                    "dark": {
                        "backgroundColor": "#000000"
                    }
                }
            ],
            "@react-native-community/datetimepicker"
        ],
        "experiments": {
            "typedRoutes": true,
            "reactCompiler": true
        },
        "extra": {
            "router": {},
            "eas": {
                "projectId": "c1785105-5c9d-4346-9366-be9e499d6906"
            }
        }
    }
}
