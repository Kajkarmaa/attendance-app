{
    "expo": {
        "name": "Soni Jewellers",
        "slug": "attendance",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/logo.png",
        "scheme": "attendance",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": true
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#FFFFFF",
                "foregroundImage": "./assets/logo.png"
            },
            "edgeToEdgeEnabled": true,
            "predictiveBackGestureEnabled": false,
            "package": "com.attendanceapp.main",
            "permissions": [
                "android.permission.CAMERA",
                "android.permission.ACCESS_FINE_LOCATION",
                "android.permission.ACCESS_COARSE_LOCATION",
                "android.permission.USE_BIOMETRIC",
                "android.permission.USE_FINGERPRINT"
            ],
            "blockedPermissions": [
                "android.permission.RECORD_AUDIO"
            ]
        },
        "web": {
            "output": "static",
            "favicon": "./assets/logo.png"
        },
        "plugins": [
            "expo-router",
            [
                "expo-splash-screen",
                {
                    "image": "./assets/logo.png",
                    "imageWidth": 200,
                    "resizeMode": "contain",
                    "backgroundColor": "#ffffff",
                    "dark": {
                        "backgroundColor": "#000000"
                    }
                }
            ],
            "@react-native-community/datetimepicker",
            "expo-secure-store",
            [
                "expo-image-picker",
                {
                    "cameraPermission": "Allow Soni Jewellers to use the camera so you can capture check-in and profile photos.",
                    "photosPermission": "Allow Soni Jewellers to access your photos so you can upload a profile picture.",
                    "microphonePermission": false
                }
            ],
            [
                "expo-location",
                {
                    "locationWhenInUsePermission": "Soni Jewellers uses your location to verify check-ins from approved sites.",
                    "isAndroidBackgroundLocationEnabled": false,
                    "isAndroidForegroundServiceEnabled": false
                }
            ],
            [
                "expo-local-authentication",
                {
                    "faceIDPermission": "Allow Soni Jewellers to use Face ID for secure check-in and check-out."
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true,
            "reactCompiler": true
        },
        "extra": {
            "router": {},
            "eas": {
                "projectId": "5ae4cd21-8706-4409-8d3f-d5d914dc734d"
            }
        }
    }
}
